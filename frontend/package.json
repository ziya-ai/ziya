    "svgo": "^3.0.0",
    "glob": "^11.0.4",
    "qs": ">=6.15.0",
    "serialize-javascript": ">=7.0.3",
    "express": "^4.21.2",
    "body-parser": "^1.20.3",
    "send": "^1.2.0",
    "serve-static": "^2.2.0",
    "cookie": "^1.0.2",
    "path-to-regexp": "^8.0.0",
    "debug": "^4.4.0",
    "semver": "^7.7.0",
    "minimatch": "^9.0.0",
    "fork-ts-checker-webpack-plugin": {
      "minimatch": "^3.1.2"
    },
